# Copy to Vercel → Project Settings → Environment Variables (Production + Preview).
# Supabase: Dashboard → Project Settings → API
#
# Parent registration (/api/register-parent) requires SUPABASE_SERVICE_ROLE_KEY on the same
# Vercel project as this site (server creates a confirmed user so sign-in works immediately).

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_ANON_KEY=
# Service role JWT from Supabase → Project Settings → API (same value as legacy name below).
SUPABASE_SERVICE_ROLE_KEY=
# Optional legacy name; the API also reads this if ROLE_KEY is unset.
SUPABASE_SERVICE_KEY=

# Site URL for Stripe redirects (no trailing slash)
BASE_URL=https://your-deployment.vercel.app

# Stripe (checkout) — use matching mode: both test (sk_test_ / pk_test_) or both live.
STRIPE_SECRET_KEY=
# Publishable key for Stripe.js (safe in browser; served via /api/public-config)
STRIPE_PUBLISHABLE_KEY=
# Alternative name (some stacks use NEXT_PUBLIC_* for client keys)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: extra T-shirt add-on at checkout (default 20 if unset)
# EXTRA_CAMP_SHIRT_USD=20

# Webhook signing secret for POST /api/webhook (checkout.session.completed).
# Stripe Dashboard → Developers → Webhooks → Add endpoint → URL: https://YOUR_DOMAIN/api/webhook
# → Select event checkout.session.completed → Reveal "Signing secret" → paste here.
# CLI (forward to local): stripe listen --forward-to localhost:3000/api/webhook  (prints whsec_...)
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Resend (transactional email). Without RESEND_API_KEY, all sends are skipped.
# Get an API key: https://resend.com/api-keys
# Optional RESEND_FROM; if unset, code uses: IMA Summer Camp <onboarding@resend.dev>
# RESEND_FROM=IMA Summer Camp <onboarding@resend.dev>
# RESEND_API_KEY=re_...
